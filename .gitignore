# Virtual environment — never push this
venv/
env/

# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# Large model files — too big for GitHub
*.bin
*.pt
*.pth
*.safetensors

# Large data files — use download script instead
*.zip
*.tar.gz
*.csv

# JSON: ignore by default (HF caches, etc.), but allow repo config + splits + results
*.json
!pyrightconfig.json
!basedpyrightconfig.json
!data/processed/*.json
!data/index/index_meta*.json
!results/*.json

# FAISS indexes and passage stores — rebuild with src/build_index.py / compare_embedders
data/index/*.pkl
data/index/*.index

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
